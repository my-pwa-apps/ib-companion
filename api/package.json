{
  "name": "ib-companion-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ib-companion-db",
    "db:migrate": "wrangler d1 migrations apply ib-companion-db",
    "db:migrate:local": "wrangler d1 execute ib-companion-db --local --file=./migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute ib-companion-db --remote --file=./migrations/0001_initial.sql",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:sql": "wrangler d1 execute ib-companion-db --local --file=./migrations/seed_test_data.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
